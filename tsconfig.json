{
  "compilerOptions": {
    "module": "preserve",
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "outDir": "dist",
    "resolveJsonModule": true
  },
  "exclude": ["scripts"]
}
