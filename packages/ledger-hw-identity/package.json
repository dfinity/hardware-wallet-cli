{
  "name": "@dfinity/ledger-hw-identity",
  "version": "0.1.0",
  "description": "Ledger hardware wallet identity for the Internet Computer",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
